    },
    {
      "name": "Zulya",
      "media_title": "Lobo",
      "tropes": [
        "BitchInSheepsClothing",
        "NavelWindow",
        "HumanAliens"
      ],
      "description": "Bitch in Sheep's Clothing: Comes across as a nice and bubbly family member of Darlene's family but secretly plots to kill her. Human Aliens: Like so many other characters associated with Lobo, she looks like a human despite being an alien. Navel Window: Her dress has an opening for her midriff.",
      "source": "tvtropes"
    },
    {
      "name": "Dr Flik",
      "media_title": "Lobo",
      "tropes": [
        "AllGirlsWantBadBoys",
        "MsFanservice",
        "DarkandTroubledPast",
        "CharacterDevelopment",
        "FreudianExcuse"
      ],
      "description": "All Girls Want Bad Boys: She admits to feeling attracted to Lobo, despite his villainous status. Character Development: She starts out being an impartial observer, but eventually gets involved in saving the universe and sees different sides to people. Dark and Troubled Past: She had to watch her world and her parents die as a child. Freudian Excuse: She wished to honor her deceased parents by travelling the universe and witnessing all its heroes. Ms. Fanservice: She wears a skintight dress over a distinct hourglass figure.",
      "source": "tvtropes"
    }
  ],
